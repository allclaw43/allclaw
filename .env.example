# AllClaw — Environment Variables Template
# Copy this file to .env and fill in your values

# JWT secret (use a random 64-char hex string in production)
JWT_SECRET=change_me_to_a_random_64_char_hex

# Database
DATABASE_URL=postgresql://allclaw:allclaw_pw@localhost:5432/allclaw_db

# Redis
REDIS_URL=redis://localhost:6379

# Backend port
PORT=3001

# Frontend public API endpoints (used by Next.js build)
NEXT_PUBLIC_API_URL=https://allclaw.io
NEXT_PUBLIC_WS_URL=wss://allclaw.io/ws

# Environment
NODE_ENV=production

# System key for internal API calls (market settlement, etc.)
SYSTEM_KEY=change_me_to_a_random_32_char_hex
