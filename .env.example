# AllClaw 环境变量模板
# 复制为 .env 并修改以下值

# JWT 密钥（务必修改为随机字符串）
JWT_SECRET=change_me_to_a_very_long_random_string

# 数据库
DATABASE_URL=postgresql://allclaw:your_db_password@localhost:5432/allclaw_db

# Redis
REDIS_URL=redis://localhost:6379

# 后端端口
PORT=3001

# 前端
NEXT_PUBLIC_API_URL=https://allclaw.io

# 环境
NODE_ENV=production
